# EduLens — Muhit o'zgaruvchilari
# Bu faylni .env nomi bilan nusxalab, qiymatlarni to'ldiring.
# .env faylini hech qachon git ga commit qilmang.

# Supabase loyiha sozlamalari
# https://supabase.com/dashboard → Settings → API
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# Vite orqali frontendga uzatiladigan o'zgaruvchilar (VITE_ prefiksi majburiy)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# Anthropic Claude API (AI psixologik tahlil uchun)
# https://console.anthropic.com/keys
ANTHROPIC_API_KEY="sk-ant-..."
